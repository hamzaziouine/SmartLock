  {"id":"mqtt-in-tlm","type":"mqtt in","z":"sl-flow-tab","name":"GUID/telemetry","topic":"GUID/telemetry","qos":"0","datatype":"json","broker":"sl-mqtt-broker","x":120,"y":80,"wires":[["fn-route"]]},

  {"id":"fn-route","type":"function","z":"sl-flow-tab","name":"fn-route","func":"var t = msg.payload.type;\nif (t === 'uid')   return [msg, null, null];\nif (t === 'state') return [null, msg, null];\nif (t === 'ready') return [null, null, msg];\nreturn [null, null, null];","outputs":3,"x":310,"y":80,"wires":[["fn-whitelist-check"],["fn-state-update"],["fn-ready"]]},

  {"id":"fn-whitelist-check","type":"function","z":"sl-flow-tab","name":"fn-whitelist-check","func":"var wl = flow.get('whitelist');\nif (!wl) { wl = ['4C8A285D']; flow.set('whitelist', wl); }\nvar uid = (msg.payload.uid || '').toUpperCase().trim();\nvar authorized = wl.indexOf(uid) !== -1;\nvar now = new Date();\nvar ts = now.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',second:'2-digit'});\nvar entry = {ts: ts, uid: uid, ok: authorized, epoch: now.getTime()};\nvar history = flow.get('history') || [];\nhistory.unshift(entry);\nif (history.length > 20) history = history.slice(0, 20);\nflow.set('history', history);\nvar counts = flow.get('counts') || {total:0, auth:0, denied:0};\ncounts.total = (counts.total || 0) + 1;\nif (authorized) { counts.auth = (counts.auth || 0) + 1; } else { counts.denied = (counts.denied || 0) + 1; }\nflow.set('counts', counts);\nflow.set('lastUID', uid);\nflow.set('lastVerdict', authorized ? 'AUTHORIZED' : 'DENIED');\nflow.set('lastTs', ts);\nvar cmd = authorized ? 'open' : 'alarm';\nvar cmdMsg = {topic: 'GUID/commands', payload: cmd};\nvar statsMsg = {payload: {history: history, counts: counts, lastUID: uid, lastVerdict: authorized ? 'AUTHORIZED' : 'DENIED', lastTs: ts}};\nreturn [cmdMsg, statsMsg];","outputs":2,"x":540,"y":60,"wires":[["mqtt-out-cmd"],["fn-stats-dispatch"]]},

  {"id":"fn-stats-dispatch","type":"function","z":"sl-flow-tab","name":"fn-stats-dispatch","func":"var d = msg.payload;\nvar counts = d.counts;\nvar history = d.history;\nvar lastUID = d.lastUID;\nvar lastVerdict = d.lastVerdict;\nvar lastTs = d.lastTs;\nvar msg1 = {payload: counts.total};\nvar msg2 = {payload: counts.auth};\nvar msg3 = {payload: counts.denied};\nvar msg4 = {payload: {uid: lastUID, verdict: lastVerdict, ts: lastTs}};\nvar msg5 = {payload: history};\nvar now = Date.now();\nvar bucket = Math.floor(now / 60000);\nvar scanBuckets = flow.get('scanBuckets') || {};\nscanBuckets[bucket] = (scanBuckets[bucket] || 0) + 1;\nvar cutoff = bucket - 15;\nvar keys = Object.keys(scanBuckets).map(Number);\nkeys.forEach(function(k){ if (k < cutoff) { delete scanBuckets[k]; } });\nflow.set('scanBuckets', scanBuckets);\nvar chartPoints = [];\nfor (var i = 14; i >= 0; i--) {\n  var b = bucket - i;\n  var label = (14 - i) + 'm';\n  chartPoints.push({x: label, y: scanBuckets[b] || 0});\n}\nvar msg6 = {topic: 'Scans/min', payload: chartPoints.map(function(p){ return p.y; })};\nreturn [msg1, msg2, msg3, msg4, msg5, msg6];","outputs":6,"x":800,"y":60,"wires":[["ui-card-total"],["ui-card-auth"],["ui-card-denied"],["ui-card-last"],["ui-timeline"],["ui-chart-scans"]]},

  {"id":"ui-card-total","type":"ui_template","z":"sl-flow-tab","group":"sl-grp-overview","order":1,"width":"3","height":"2","name":"ui-card-total","format":"<style>.slct{background:#161b27;border:1px solid #2d3748;border-radius:10px;padding:16px 20px;font-family:Inter,system-ui,sans-serif;text-align:center}.slct .lbl{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#64748b;margin-bottom:8px}.slct .val{font-size:42px;font-weight:700;color:#00d4ff;line-height:1}.slct .sub{font-size:11px;color:#475569;margin-top:6px}</style><div class=\"slct\"><div class=\"lbl\">Total Scans</div><div class=\"val\">{{msg.payload || 0}}</div><div class=\"sub\">all attempts today</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":1060,"y":20,"wires":[[]]},

