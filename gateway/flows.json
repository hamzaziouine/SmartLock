  {"id":"fn-wl-mutate","type":"function","z":"sl-flow-tab","name":"fn-wl-mutate","func":"var uid = (flow.get('wl_pending_uid') || '').toUpperCase().trim();\nvar wl = flow.get('whitelist') || ['4C8A285D'];\nif (!uid) {\n  msg.payload = wl;\n  return msg;\n}\nif (msg.payload === 'add' && wl.indexOf(uid) === -1) {\n  wl.push(uid);\n}\nif (msg.payload === 'remove') {\n  wl = wl.filter(function(x){ return x !== uid; });\n}\nflow.set('whitelist', wl);\nmsg.payload = wl;\nreturn msg;","outputs":1,"x":340,"y":500,"wires":[["ui-wl-display"]]},

  {"id":"ui-wl-display","type":"ui_template","z":"sl-flow-tab","group":"sl-grp-whitelist","order":4,"width":"12","height":"3","name":"ui-wl-display","format":"<style>.sl-wl{font-family:Inter,system-ui,sans-serif}.sl-wl-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#64748b;margin-bottom:10px}.sl-wl-list{display:flex;flex-wrap:wrap;gap:8px}.sl-wl-chip{background:#1e3a5f;border:1px solid #1d4ed8;border-radius:6px;padding:6px 14px;font-family:'Courier New',monospace;font-size:13px;letter-spacing:2px;color:#93c5fd;font-weight:600}.sl-wl-empty{color:#475569;font-size:13px;font-style:italic}</style><div class=\"sl-wl\"><div class=\"sl-wl-title\">Authorized UIDs</div><div class=\"sl-wl-list\" ng-if=\"msg.payload && msg.payload.length > 0\"><div ng-repeat=\"uid in msg.payload track by $index\" class=\"sl-wl-chip\">{{uid}}</div></div><div class=\"sl-wl-empty\" ng-if=\"!msg.payload || msg.payload.length === 0\">No UIDs in whitelist — all access denied.</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":560,"y":500,"wires":[[]]},

  {"id":"fn-ready","type":"function","z":"sl-flow-tab","name":"fn-ready","func":"node.warn('SmartLock: READY signal received from Arduino');\nreturn null;","outputs":1,"x":520,"y":40,"wires":[[]]},

  {"id":"fn-init-wl","type":"inject","z":"sl-flow-tab","name":"init-whitelist","props":[{"p":"payload"}],"repeat":"","crontab":"","once":true,"onceDelay":"0.5","topic":"","payload":"init","payloadType":"str","x":120,"y":580,"wires":[["fn-init-exec"]]},

  {"id":"fn-init-exec","type":"function","z":"sl-flow-tab","name":"fn-init-exec","func":"if (!flow.get('whitelist')) { flow.set('whitelist', ['4C8A285D']); }\nif (!flow.get('counts')) { flow.set('counts', {total:0, auth:0, denied:0}); }\nif (!flow.get('history')) { flow.set('history', []); }\nif (!flow.get('scanBuckets')) { flow.set('scanBuckets', {}); }\nvar wl = flow.get('whitelist');\nreturn {payload: wl};","outputs":1,"x":340,"y":580,"wires":[["ui-wl-display"]]}
