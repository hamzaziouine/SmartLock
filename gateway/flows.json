  {"id":"ui-card-denied","type":"ui_template","z":"sl-flow-tab","group":"sl-grp-overview","order":3,"width":"3","height":"2","name":"ui-card-denied","format":"<style>.slcd{background:#161b27;border:1px solid #2d3748;border-radius:10px;padding:16px 20px;font-family:Inter,system-ui,sans-serif;text-align:center}.slcd .lbl{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#64748b;margin-bottom:8px}.slcd .val{font-size:42px;font-weight:700;color:#ef4444;line-height:1}.slcd .sub{font-size:11px;color:#475569;margin-top:6px}</style><div class=\"slcd\"><div class=\"lbl\">Denied</div><div class=\"val\">{{msg.payload || 0}}</div><div class=\"sub\">rejected attempts</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":1060,"y":100,"wires":[[]]},

  {"id":"ui-card-last","type":"ui_template","z":"sl-flow-tab","group":"sl-grp-overview","order":4,"width":"3","height":"2","name":"ui-card-last","format":"<style>.slcl{background:#161b27;border:1px solid #2d3748;border-radius:10px;padding:16px 20px;font-family:Inter,system-ui,sans-serif;text-align:center}.slcl .lbl{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#64748b;margin-bottom:8px}.slcl .uid{font-size:20px;font-weight:700;font-family:'Courier New',monospace;color:#f8fafc;letter-spacing:2px}.slcl .badge{font-size:10px;font-weight:700;letter-spacing:1px;margin-top:6px;padding:3px 10px;border-radius:20px;display:inline-block}.slcl .ok{background:#064e3b;color:#34d399}.slcl .deny{background:#7f1d1d;color:#fca5a5}.slcl .ts{font-size:10px;color:#475569;margin-top:4px}</style><div class=\"slcl\"><div class=\"lbl\">Last Scan</div><div class=\"uid\">{{msg.payload.uid || '—'}}</div><div ng-if=\"msg.payload.verdict\" class=\"badge\" ng-class=\"msg.payload.verdict === 'AUTHORIZED' ? 'ok' : 'deny'\">{{msg.payload.verdict}}</div><div class=\"ts\">{{msg.payload.ts || ''}}</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":1060,"y":140,"wires":[[]]},

  {"id":"fn-state-update","type":"function","z":"sl-flow-tab","name":"fn-state-update","func":"var state = (msg.payload.state || 'LOCKED').toUpperCase();\nflow.set('doorState', state);\nmsg.payload = state;\nreturn msg;","outputs":1,"x":520,"y":180,"wires":[["ui-hero-state"]]},

  {"id":"ui-hero-state","type":"ui_template","z":"sl-flow-tab","group":"sl-grp-door","order":1,"width":"6","height":"4","name":"ui-hero-state","format":"<style>.sl-hero{display:flex;flex-direction:column;align-items:center;justify-content:center;height:160px;border-radius:12px;font-family:Inter,system-ui,sans-serif;transition:background 0.6s ease,box-shadow 0.6s ease;margin-bottom:8px}.sl-hero.OPEN{background:linear-gradient(135deg,#064e3b,#065f46);box-shadow:0 0 40px rgba(16,185,129,0.35)}.sl-hero.LOCKED{background:linear-gradient(135deg,#1e293b,#334155);box-shadow:0 0 20px rgba(0,0,0,0.4)}.sl-hero.ALARM{background:linear-gradient(135deg,#7f1d1d,#991b1b);box-shadow:0 0 40px rgba(239,68,68,0.5);animation:pulse-alarm 1s ease-in-out infinite alternate}@keyframes pulse-alarm{from{box-shadow:0 0 20px rgba(239,68,68,0.3)}to{box-shadow:0 0 60px rgba(239,68,68,0.8)}}.sl-hero-icon{font-size:52px;margin-bottom:10px}.sl-hero-state{font-size:32px;font-weight:800;letter-spacing:4px}.sl-hero.OPEN .sl-hero-state{color:#34d399}.sl-hero.LOCKED .sl-hero-state{color:#94a3b8}.sl-hero.ALARM .sl-hero-state{color:#fca5a5}.sl-hero-sub{font-size:11px;letter-spacing:2px;text-transform:uppercase;margin-top:6px;opacity:0.6}</style><div class=\"sl-hero {{msg.payload || 'LOCKED'}}\"><div class=\"sl-hero-icon\">{{msg.payload === 'OPEN' ? '🔓' : msg.payload === 'ALARM' ? '🚨' : '🔒'}}</div><div class=\"sl-hero-state\">{{msg.payload || 'LOCKED'}}</div><div class=\"sl-hero-sub\">door state</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":740,"y":180,"wires":[[]]},

