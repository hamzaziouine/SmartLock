  {"id":"ui-timeline","type":"ui_template","z":"sl-flow-tab","group":"sl-grp-activity","order":1,"width":"6","height":"6","name":"ui-timeline","format":"<style>.sl-tl{font-family:Inter,system-ui,sans-serif;height:240px;overflow-y:auto}.sl-tl::-webkit-scrollbar{width:4px}.sl-tl::-webkit-scrollbar-track{background:#0d1117}.sl-tl::-webkit-scrollbar-thumb{background:#2d3748;border-radius:2px}.sl-tl-hdr{display:grid;grid-template-columns:80px 1fr 70px;gap:8px;padding:6px 10px;border-bottom:1px solid #2d3748;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#64748b}.sl-tl-row{display:grid;grid-template-columns:80px 1fr 70px;gap:8px;padding:7px 10px;border-bottom:1px solid #1e293b;font-size:12px}.sl-tl-row.ok{border-left:3px solid #10b981}.sl-tl-row.deny{border-left:3px solid #ef4444}.sl-tl-ts{color:#64748b;font-size:11px}.sl-tl-uid{font-family:'Courier New',monospace;letter-spacing:1px;color:#e2e8f0;font-size:12px}.sl-tl-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;text-align:center}.ok .sl-tl-badge{background:#064e3b;color:#34d399}.deny .sl-tl-badge{background:#7f1d1d;color:#fca5a5}</style><div class=\"sl-tl\"><div class=\"sl-tl-hdr\"><span>Time</span><span>UID</span><span>Result</span></div><div ng-repeat=\"e in msg.payload track by $index\" class=\"sl-tl-row\" ng-class=\"e.ok ? 'ok' : 'deny'\"><span class=\"sl-tl-ts\">{{e.ts}}</span><span class=\"sl-tl-uid\">{{e.uid}}</span><span class=\"sl-tl-badge\">{{e.ok ? 'OK' : 'DENY'}}</span></div><div ng-if=\"!msg.payload || msg.payload.length === 0\" style=\"padding:20px;text-align:center;color:#475569;font-size:12px\">No events yet — waiting for RFID scans...</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":1060,"y":200,"wires":[[]]},

